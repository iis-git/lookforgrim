# App
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://your-frontend-domain.com

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=lookforgrim
DB_PASSWORD=change-me-db-password
DB_NAME=lookforgrim
DB_SSL=false
DB_LOGGING=false

# Auth
JWT_ACCESS_SECRET=change-me-super-long-access-secret
JWT_REFRESH_SECRET=change-me-super-long-refresh-secret
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=2592000
PASSWORD_SALT_ROUNDS=12

# One-time admin setup
INIT_ADMIN_SETUP_TOKEN=change-me-setup-token

# Media (local filesystem)
UPLOADS_DIR=/app/uploads
MEDIA_BASE_URL=/media
